# ============================================
# The Bake Stories - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/thebakestories
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/thebakestories

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Cloudinary (Required for image storage)
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Instagram Basic Display API (Optional - for auto-fetching images)
# Get token from: https://developers.facebook.com/docs/instagram-basic-display-api
IG_ACCESS_TOKEN=
IG_USER_ID=thebakestories05

# Bakery Contact (Required for COD call flow)
BAKERY_PHONE=+91xxxxxxxxxx
BAKERY_NAME=The Bake Stories
BAKERY_EMAIL=orders@thebakestories.example

# Twilio (Optional - for SMS/WhatsApp notifications)
# Get credentials from: https://www.twilio.com/console
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+1xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+1xxxxxxxxxx

# SendGrid (Optional - for email notifications)
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
EMAIL_FROM=orders@thebakestories.example
EMAIL_FROM_NAME=The Bake Stories

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Admin Configuration
ADMIN_EMAIL=admin@thebakestories.example
ADMIN_PASSWORD=change-this-password

# Order Settings
CALL_CONFIRM_HOURS=24
DELIVERY_SLOTS=morning,afternoon,evening
