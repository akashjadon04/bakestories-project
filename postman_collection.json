              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Confirmed via phone call\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/orders/admin/:orderId/confirm",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "admin", ":orderId", "confirm"]
            }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"preparing\",\n  \"note\": \"Order is being prepared\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/orders/admin/:orderId/status",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "admin", ":orderId", "status"]
            }
          }
