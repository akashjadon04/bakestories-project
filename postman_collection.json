    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order (COD)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"product\": \"product_id_here\",\n      \"quantity\": 1\n    }\n  ],\n  \"customerName\": \"John Doe\",\n  \"customerEmail\": \"john@example.com\",\n  \"customerPhone\": \"+911234567890\",\n  \"deliveryAddress\": {\n    \"street\": \"123 Main Street\",\n    \"city\": \"Mumbai\",\n    \"state\": \"Maharashtra\",\n    \"pincode\": \"400001\"\n  },\n  \"deliveryDate\": \"2024-01-20\",\n  \"deliveryTime\": \"afternoon\",\n  \"paymentMethod\": \"cod\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/orders/create",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "create"]
            }
          }
        },
        {
          "name": "Validate Coupon",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"WELCOME10\",\n  \"cartTotal\": 1000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/orders/validate-coupon",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "validate-coupon"]
            }
          }
        },
        {
          "name": "Track Order",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/orders/track/BS202401150001?phone=+911234567890",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "track", "BS202401150001"],
              "query": [{"key": "phone", "value": "+911234567890"}]
            }
          }
        }
      ]
    },
    {
